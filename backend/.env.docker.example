# 后端API认证密钥（⚠️ 生产环境必须修改！建议使用 uuidgen 或 openssl rand -hex 32 生成随机字符串）
API_KEY=zxf199333

# 服务器配置（⚠️ 必须与 Dockerfile 的 EXPOSE 端口一致）
SERVER_PORT=8900

# 服务器对外访问地址（PDA扫码配置二维码和APK下载使用此地址）
# - 内网部署：留空会自动从请求 Host 获取（如 http://192.168.1.100:8900）
# - 跨网络/FRP穿透：取消注释并填写公网地址，如：
SERVER_URL=https://frp-off.com:64623

# CORS跨域来源（多个地址用逗号分隔，生产环境建议限制为具体IP）
# 内网PDA场景可设为 *，公网部署需限制
CORS_ORIGINS=*

# 快麦API会话过期预警天数（默认5天，可选）
SESSION_WARNING_DAYS=5

# 快麦凭证加密密钥（AES-256-GCM，Base64编码的32字节密钥）
# 生成命令: openssl rand -base64 32
# 留空或删除则保持明文JSON存储（兼容旧版）
# KUAIMAI_CONFIG_KEY=
