# 后端API认证密钥（必填，建议使用 uuidgen 生成随机字符串）
API_KEY=zxf199333

# 服务器配置
SERVER_PORT=8900

# 服务器对外访问地址（必填，PDA扫码配置二维码会使用此地址）
# 格式: http://你的NAS_IP:端口，例如 http://192.168.1.100:8900
SERVER_URL=http://YOUR_NAS_IP:8900

# CORS跨域来源（多个地址用逗号分隔，生产环境建议限制为具体IP）
# 内网PDA场景可设为 *，公网部署需限制
CORS_ORIGINS=*

# 快麦API会话过期预警天数（默认5天，可选）
SESSION_WARNING_DAYS=5
